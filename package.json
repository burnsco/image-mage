{
  "name": "image-mage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "check": "bun run lint && bun run typecheck",
    "build:workers": "opennextjs-cloudflare build",
    "deploy": "bun run build:workers && wrangler deploy",
    "cf:status": "../scripts/cf-portfolio.sh status image-mage",
    "biome": "biome check .",
    "biome:fix": "biome format . --write",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@opennextjs/cloudflare": "^1.18.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.2",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.0"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
