{
  "name": "image-mage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "check": "bun run lint && bun run typecheck",
    "build:workers": "opennextjs-cloudflare build",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "biome": "biome check .",
    "biome:fix": "biome format . --write",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@opennextjs/cloudflare": "^1.19.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.2",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.0"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
