{
  "name": "image-mage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "check": "bun run lint && bun run typecheck",
    "build:workers": "opennextjs-cloudflare build",
    "deploy": "bun run build:workers && wrangler deploy",
    "cf:status": "../scripts/cf-portfolio.sh status image-mage",
    "biome": "biome check .",
    "biome:fix": "biome format . --write",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix . && oxfmt",
    "format:check": "prettier . --check",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "next": "16.1.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.74.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
