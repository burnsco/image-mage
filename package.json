{
  "name": "image-mage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build",
    "check": "bun run lint && bun run typecheck && bun run test",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "test": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix . && oxfmt .",
    "format:check": "oxfmt --check .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
