{
  "name": "image-mage",
  "compatibility_date": "2026-02-05",
  "main": "worker.ts",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
  },
  "routes": [
